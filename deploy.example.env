# Скопируйте в .env в корне репозитория на сервере: cp deploy.example.env .env
# docker compose автоматически подхватывает .env рядом с docker-compose.yml

# --- Домен (обязательно согласовать с DNS) ---
# A/AAAA: sommeal.ru → IP сервера; для Let's Encrypt порты 80 и 443 снаружи
# API доступен на том же хосте по пути /api (same-origin, см. Caddyfile)
APP_DOMAIN=sommeal.ru

# Публичный URL фронта — для CORS и ссылок из бэкенда (с https://)
FRONTEND_ORIGIN=https://sommeal.ru

# Email для ACME (Let's Encrypt) в Caddy
CADDY_ACME_EMAIL=vldmrelizarov@yandex.ru

# Редкий фолбэк в axios (полный URL с /api; обычно совпадает с https://APP_DOMAIN/api)
VITE_BACKEND_FALLBACK_URL=https://sommeal.ru/api

# --- Секреты (сгенерируйте новые для продакшена) ---
SECRET_KEY=e457f257543104d2d81fd6bf41f2a6ff9240646147ac7e991e3f8998a8f8bdb5
JWT_SECRET=amVngWKDkBVoU24x/ptgau67vu1JGkFNOYPy/ujRMB4=

# --- Web Push (опционально; публичный ключ должен совпасть с бэкендом) ---
VITE_VAPID_PUBLIC_KEY=

# --- MinIO (смените дефолты в продакшене) ---
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# --- Опционально: своя строка подключения к Postgres (если БД не из compose) ---
# DATABASE_URL=postgresql://user:pass@host:5432/kindplate
